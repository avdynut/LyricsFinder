<UserControl x:Class="Lyrixound.Views.LyricsSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:vm="clr-namespace:Lyrixound.ViewModels"
             d:DataContext="{d:DesignInstance vm:LyricsSettingsViewModel}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d">

    <StackPanel>
        <TextBlock Margin="0,5,0,0"
                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                   Text="Font Size"/>
        <Slider IsMoveToPointEnabled="True"
                Maximum="200"
                Minimum="7"
                Style="{DynamicResource MaterialDesignDiscreteSlider}"
                ToolTip="{Binding FontSize}"
                Value="{Binding FontSize}"/>

        <TextBlock Margin="0,5,0,0"
                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                   Text="Floating Background Opacity"/>
        <Slider IsMoveToPointEnabled="True"
                Maximum="1"
                Minimum="0"
                SmallChange="0.01"
                Style="{DynamicResource MaterialDesignDiscreteSlider}"
                TickFrequency="0.01"
                ToolTip="{Binding FloatingBackgroundOpacity, StringFormat=F2}"
                Value="{Binding FloatingBackgroundOpacity, StringFormat=F2}"/>

        <TextBlock Margin="0,5,0,0"
                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                   Text="Synced Lyrics Time Offset (seconds)"/>
        <Grid Margin="0,5,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Slider Grid.Column="0"
                    VerticalAlignment="Center"
                    IsMoveToPointEnabled="True"
                    Maximum="10"
                    Minimum="-10"
                    SmallChange="0.1"
                    Style="{DynamicResource MaterialDesignDiscreteSlider}"
                    TickFrequency="0.1"
                    ToolTip="{Binding TimeOffsetSeconds, StringFormat=F3}"
                    Value="{Binding TimeOffsetSeconds}"/>
            <TextBox Grid.Column="1"
                     Width="60"
                     Margin="10,0,0,0"
                     md:HintAssist.Hint="sec"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     Text="{Binding TimeOffsetSeconds, StringFormat=F3, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Adjust synced lyrics timing. Positive values move lyrics forward, negative values move them backward."/>
        </Grid>

        <ToolBar Style="{DynamicResource MaterialDesignToolBar}">
            <ListBox ItemsSource="{Binding TextAlignments}"
                     SelectedValue="{Binding TextAlignment}"
                     SelectedValuePath="Key"
                     Style="{StaticResource MaterialDesignToolToggleListBox}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <md:PackIcon Kind="{Binding Value}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Separator/>

            <ListBox SelectionMode="Extended" Style="{StaticResource MaterialDesignToolToggleFlatListBox}">
                <ListBoxItem IsSelected="{Binding IsBold}">
                    <md:PackIcon Kind="FormatBold"/>
                </ListBoxItem>
                <ListBoxItem IsSelected="{Binding IsItalic}">
                    <md:PackIcon Kind="FormatItalic"/>
                </ListBoxItem>
            </ListBox>

            <Separator/>

            <ComboBox ItemsSource="{Binding Source={x:Static Fonts.SystemFontFamilies}}" SelectedItem="{Binding FontFamily}"/>
        </ToolBar>

        <WrapPanel Margin="10,0">
            <TextBox MinWidth="100"
                     md:HintAssist.Hint="Blur Radius"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     Text="{Binding BlurRadius, UpdateSourceTrigger=PropertyChanged, Delay=200}"/>
            <TextBox MinWidth="100"
                     Margin="10,0,0,0"
                     md:HintAssist.Hint="Shadow Depth"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     Text="{Binding ShadowDepth, UpdateSourceTrigger=PropertyChanged, Delay=200}"/>
        </WrapPanel>

        <WrapPanel Margin="10,0,10,10">
            <StackPanel Orientation="Horizontal">
                <Rectangle Width="20"
                           Height="20"
                           VerticalAlignment="Bottom">
                    <Rectangle.Fill>
                        <SolidColorBrush Color="{Binding TextColor}"/>
                    </Rectangle.Fill>
                </Rectangle>
                <TextBox MinWidth="100"
                         md:HintAssist.Hint="Text Color"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Text="{Binding TextColor, UpdateSourceTrigger=PropertyChanged, Delay=200}"/>
            </StackPanel>

            <StackPanel Margin="10,0,0,0" Orientation="Horizontal">
                <Rectangle Width="20"
                           Height="20"
                           VerticalAlignment="Bottom">
                    <Rectangle.Fill>
                        <SolidColorBrush Color="{Binding ShadowColor}"/>
                    </Rectangle.Fill>
                </Rectangle>
                <TextBox MinWidth="100"
                         md:HintAssist.Hint="Shadow Color"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Text="{Binding ShadowColor, UpdateSourceTrigger=PropertyChanged, Delay=200}"/>
            </StackPanel>

            <StackPanel Margin="10,0,0,0" Orientation="Horizontal">
                <Rectangle Width="20"
                           Height="20"
                           VerticalAlignment="Bottom">
                    <Rectangle.Fill>
                        <SolidColorBrush Color="{Binding ActiveLineBackgroundColor}"/>
                    </Rectangle.Fill>
                </Rectangle>
                <TextBox MinWidth="100"
                         md:HintAssist.Hint="Active Line Background"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Text="{Binding ActiveLineBackgroundColor, UpdateSourceTrigger=PropertyChanged, Delay=200}"/>
            </StackPanel>
        </WrapPanel>

    </StackPanel>

</UserControl>
